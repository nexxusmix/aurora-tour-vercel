{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    { "source": "/media/(.*)",                    "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/(fonts|lib|img)/(.*)",          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/totem/(fonts|img|video)/(.*)",  "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/(index\\.html|/)",              "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }] },
    { "source": "/totem/(index\\.html)?",         "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }] },
    { "source": "/api/(.*)",                      "headers": [{ "key": "Cache-Control", "value": "no-store" }] }
  ]
}
